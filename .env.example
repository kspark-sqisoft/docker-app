# PostgreSQL (docker-compose / 로컬에서 동일 값 사용 권장)
DB_USERNAME=board
DB_PASSWORD=board
DB_NAME=board

# 백엔드 (로컬 nest start 시; Compose 에서는 compose 파일이 덮어씀)
# PORT=3000
# NODE_ENV=development

# 쉼표로 구분한 허용 Origin (비우면 모든 Origin 허용 — 개발 편의)
# CORS_ORIGIN=http://localhost:5173,http://localhost:8080

# JWT (백엔드 필수 — 최소 32자)
JWT_ACCESS_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
REFRESH_COOKIE_NAME=refresh_token
# 로컬 HTTP(5173/8080)에서는 false. HTTPS 뒤에만 true
REFRESH_COOKIE_SECURE=false

# 프로필 이미지 로컬 저장 경로(선택, 기본: backend/uploads)
# UPLOADS_DIR=D:/Study/Docker/docker_app/backend/uploads
